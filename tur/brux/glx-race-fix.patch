--- a/rte/src/brux/main.cpp
+++ b/rte/src/brux/main.cpp
@@ -210,12 +210,28 @@
 	}
 
 	// Create window
-	gvWindow = SDL_CreateWindow("Brux GDK", SDL_WINDOWPOS_UNDEFINED, SDL_WINDOWPOS_UNDEFINED, gvScrW, gvScrH, SDL_WINDOW_RESIZABLE);
+	gvWindow = SDL_CreateWindow("Brux GDK", SDL_WINDOWPOS_UNDEFINED, SDL_WINDOWPOS_UNDEFINED, gvScrW, gvScrH, SDL_WINDOW_RESIZABLE | SDL_WINDOW_OPENGL | SDL_WINDOW_SHOWN);
 
 	if (gvWindow == 0) {
 		xyPrint("Window could not be created! SDL Error: %s\n", SDL_GetError());
 		return 0;
 	} else {
+		// Ensure window is mapped by waiting for events
+		SDL_Event event;
+		bool exposed = false;
+		Uint32 start = SDL_GetTicks();
+		while (!exposed && SDL_GetTicks() - start < 1000) {
+			while (SDL_PollEvent(&event)) {
+				if (event.type == SDL_WINDOWEVENT) {
+					if (event.window.event == SDL_WINDOWEVENT_EXPOSED || event.window.event == SDL_WINDOWEVENT_SHOWN) {
+						exposed = true;
+					}
+				}
+			}
+			SDL_Delay(10);
+		}
+
+		// Force GLES2 to avoid GLX/Zink race conditions on Termux-X11
+		SDL_SetHint(SDL_HINT_RENDER_DRIVER, "opengles2");
+
 		// Create renderer for window
 		gvRender = SDL_CreateRenderer(gvWindow, -1, SDL_RENDERER_ACCELERATED);
 
@@ -224,6 +240,10 @@
 			return 0;
 		} else {
 			// Initialize renderer color
+			SDL_RendererInfo info;
+			SDL_GetRendererInfo(gvRender, &info);
+			xyPrint("Renderer: %s", info.name);
+
 			SDL_SetRenderDrawColor(gvRender, 0xFF, 0xFF, 0xFF, 0xFF);
 
 			// Initialize PNG loading
@@ -241,6 +261,11 @@
 			// Set the mimumum window size
 			// No idea why it didn't do this before.
 			SDL_SetWindowMinimumSize(gvWindow, gvScrW, gvScrH);
+
+			// Warm up the renderer
+			SDL_RenderClear(gvRender);
